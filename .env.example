# ===================================================================
# BazarBD — Environment Variables
# Copy to .env.local and fill in your values
# ===================================================================

# ── General ─────────────────────────────────────────────────
NODE_ENV=development
PORT=4001

# ── PostgreSQL ──────────────────────────────────────────────
DB_HOST=localhost
DB_PORT=5432
DB_USER=bazarbd
DB_PASSWORD=bazarbd_secret
DB_NAME=bazarbd

# ── Redis ───────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379

# ── JWT ─────────────────────────────────────────────────────
JWT_SECRET=your-jwt-secret-change-in-production
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# ── CORS ────────────────────────────────────────────────────
CORS_ORIGINS=http://localhost:3000,http://localhost:3001

# ── Elasticsearch ───────────────────────────────────────────
ELASTICSEARCH_URL=http://localhost:9200

# ── Kafka ───────────────────────────────────────────────────
KAFKA_BROKERS=localhost:9092
KAFKA_CLIENT_ID=bazarbd

# ── R2 / S3 (Product Images) ───────────────────────────────
R2_ACCOUNT_ID=your-cloudflare-account-id
R2_ACCESS_KEY=your-r2-access-key
R2_SECRET_KEY=your-r2-secret-key
R2_BUCKET=bazarbd-images
R2_PUBLIC_URL=https://images.bazarbd.com

# ── bKash ───────────────────────────────────────────────────
BKASH_BASE_URL=https://tokenized.sandbox.bka.sh/v1.2.0-beta
BKASH_APP_KEY=your-bkash-app-key
BKASH_APP_SECRET=your-bkash-app-secret
BKASH_USERNAME=your-bkash-username
BKASH_PASSWORD=your-bkash-password

# ── Nagad ───────────────────────────────────────────────────
NAGAD_BASE_URL=http://sandbox.mynagad.com:10080
NAGAD_MERCHANT_ID=your-nagad-merchant-id
NAGAD_MERCHANT_PRIVATE_KEY=your-nagad-private-key
NAGAD_PUBLIC_KEY=your-nagad-public-key

# ── SSLCommerz ──────────────────────────────────────────────
SSLCOMMERZ_STORE_ID=your-sslcommerz-store-id
SSLCOMMERZ_STORE_PASSWORD=your-sslcommerz-store-password
SSLCOMMERZ_IS_LIVE=false

# ── Inter-service URLs ──────────────────────────────────────
AUTH_SERVICE_URL=http://localhost:4001
USER_SERVICE_URL=http://localhost:4002
PRODUCT_SERVICE_URL=http://localhost:4003
ORDER_SERVICE_URL=http://localhost:4004
CART_SERVICE_URL=http://localhost:4005
PAYMENT_SERVICE_URL=http://localhost:4006
INVENTORY_SERVICE_URL=http://localhost:4007
SHIPPING_SERVICE_URL=http://localhost:4008

# ── Frontend ────────────────────────────────────────────────
FRONTEND_URL=http://localhost:3000
NEXTAUTH_SECRET=your-nextauth-secret
NEXTAUTH_URL=http://localhost:3000
NEXT_PUBLIC_API_URL=http://localhost:8000
